{
  "name": "Lima",
  "author": "CubicLauncher",
  "type": "builtin",
  "bg_image": "/themes/lima/lima.webp",
  "bg_image_blur": "5px",
  "bg_image_opacity": 0.7,
  "variables": {
    "--bg-main": "#0a0f0a",
    "--bg-sidebar": "#0c110c",
    "--bg-card": "#121a12",
    "--bg-item-active": "#162016",
    "--bg-overlay": "rgba(0,10,0,0.75)",
    "--bg-input": "#161e16",
    "--text-primary": "#c8ddb0",
    "--text-secondary": "#5a7a5a",
    "--text-muted": "#3a4e3a",
    "--border-color": "#1a2e1a",
    "--border-radius": "8px",
    "--border-radius-sm": "4px",
    "--accent": "#97C459",
    "--accent-rgb": "151,196,89",
    "--accent-hover": "#a8d06a",
    "--accent-text": "#0a1a04",
    "--shadow-sm": "0 1px 3px rgba(0,0,0,0.5)",
